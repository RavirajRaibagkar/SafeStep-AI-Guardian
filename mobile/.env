# SafeStep Mobile — Environment Variables
# These are picked up by Expo as EXPO_PUBLIC_* vars (public, not secret).
#
# ─── FOR ANDROID EMULATOR (default) ───────────────────────────────────────────
# 10.0.2.2 maps to your host machine from inside the Android emulator.
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# ─── FOR PHYSICAL DEVICE (ACTIVE) ─────────────────────────────────────────────
# Your current machine LAN IP — keep the backend running on port 5000.
EXPO_PUBLIC_API_URL=http://10.220.133.140:5000/api

# ─── FOR PHYSICAL DEVICE ON THE SAME WI-FI ────────────────────────────────────
# Find your dev machine's LAN IP:
#   Windows: run  ipconfig  → look for IPv4 Address under Wi-Fi adapter
#   macOS:   run  ifconfig en0  → look for inet line
# Then replace 10.0.2.2 with that IP, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:5000/api
#
# The Socket.io URL is derived automatically from EXPO_PUBLIC_API_URL
# (strips the /api suffix). Override separately only if needed:
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.42:5000
